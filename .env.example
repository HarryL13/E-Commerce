# Changes:
# - Documented that these secrets are for Cloudflare Pages Functions now.
# - Local dev note: Wrangler reads secrets from .dev.vars (same format as
#   this file). `npm run dev` uses Vite only and doesn't need these.
#
# All five values below are SERVER-SIDE ONLY, consumed only by the
# Cloudflare Pages Functions under /functions/api. They are NEVER
# shipped to the browser.
#
# For production: set these in Cloudflare dashboard:
#   Workers & Pages -> [project] -> Settings -> Environment variables
#
# For local full-stack dev (wrangler pages dev): copy this file to
#   .dev.vars (which is gitignored).

# --- Anthropic (SKU Generator) ---
# Option A: Official Anthropic API
#   Set ANTHROPIC_API_KEY to your key from https://console.anthropic.com
#   Leave ANTHROPIC_BASE_URL empty/unset.
#
# Option B: Custom Anthropic-compatible proxy (e.g. company LiteLLM gateway)
#   Set ANTHROPIC_BASE_URL to the proxy URL (e.g. http://1.2.3.4:4000)
#   Set ANTHROPIC_AUTH_TOKEN to the proxy's bearer token
#   ANTHROPIC_API_KEY can be left unset when using a proxy.
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Gemini (Image Studio) ---
# Used by /api/gemini-analyze and /api/gemini-generate
GEMINI_API_KEY=your_gemini_api_key_here

# --- App access password ---
# Anyone with this password can use the deployed site.
APP_PASSWORD=change-me-please
